{
  "name": "securevision-local-desktop",
  "version": "0.1.16",
  "description": "SecureVision Local - Software Windows para monitoramento de câmeras WiFi/IP (NVR por software)",
  "main": "dist-electron/main.js",
  "author": "SecureVision Local",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build",
    "build:win": "npm version patch --no-git-tag-version && npm run build && electron-builder --win",
    "preview": "vite preview",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "lint": "eslint . --ext .ts,.tsx",
    "test:e2e": "npm run build && node svl-e2e-check.cjs"
  },
  "dependencies": {
    "@cycjimmy/jsmpeg-player": "^6.1.1",
    "better-sqlite3": "^11.8.1",
    "bonjour-service": "^1.3.0",
    "electron-updater": "^6.3.9",
    "ffmpeg-static": "^5.2.0",
    "fluent-ffmpeg": "^2.1.3",
    "node-ssdp": "^4.0.1",
    "onnxruntime-node": "^1.20.1",
    "onvif": "^0.7.1",
    "ws": "^8.18.0",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@types/better-sqlite3": "^7.6.12",
    "@types/fluent-ffmpeg": "^2.1.27",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@types/ws": "^8.5.13",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.1",
    "electron-builder": "^25.1.8",
    "playwright-core": "^1.61.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.7.3",
    "vite": "^6.0.7",
    "vite-plugin-electron": "^0.29.0",
    "vite-plugin-electron-renderer": "^0.14.6"
  }
}
